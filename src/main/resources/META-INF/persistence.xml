<?xml version="1.0" encoding="UTF-8"?>
<persistence version="2.2" xmlns="http://xmlns.jcp.org/xml/ns/persistence" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/persistence           http://xmlns.jcp.org/xml/ns/persistence/persistence_2_2.xsd">
  <persistence-unit name="GestorMueblesPU" transaction-type="RESOURCE_LOCAL">
    <provider>org.eclipse.persistence.jpa.PersistenceProvider</provider>
    <class>com.mycompany.gestormuebles.Logica.Proveedor</class>
    <class>com.mycompany.gestormuebles.Logica.Materiales</class>
    <class>com.mycompany.gestormuebles.Logica.CategoriaMaterial</class>
    <class>com.mycompany.gestormuebles.Logica.Proyecto</class>
    <class>com.mycompany.gestormuebles.Logica.Receta</class>
    <class>com.mycompany.gestormuebles.Logica.Usuario</class>
    <class>com.mycompany.gestormuebles.Logica.Receta_Material</class>
    <properties>
  <property name="javax.persistence.jdbc.url" value="jdbc:mysql://localhost:3306/gestormueblesdb?serverTimezone=UTC"/>
  <property name="javax.persistence.jdbc.user" value="usuario"/>
  <property name="javax.persistence.jdbc.password" value="password"/>
  <property name="javax.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>
  <property name="javax.persistence.schema-generation.database.action" value="update"/>
  <property name="javax.persistence.schema-generation.database.action" value="create"/>

  <property name="eclipselink.logging.level" value="FINE"/>
  <property name="eclipselink.logging.parameters" value="true"/>
</properties>

  </persistence-unit>
</persistence>
